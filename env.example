# EZM0.5 production env (Amazon server)
# Copy to .env and set values. Never commit .env.

# Database (Prisma - SQL Server)
DATABASE_URL="sqlserver://HOST:PORT;database=DATABASE;user=USER;password=PASSWORD;encrypt=true"

# NextAuth
NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# App
NODE_ENV=production

# SMTP (password reset / verification emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="\"EZM\" <noreply@your-domain.com>"
